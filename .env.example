# Optional: SerpAPI key for better store locator discovery
SERPAPI_KEY=

# Optional: Google Maps API key for Places fallback
GOOGLE_MAPS_API_KEY=

# Output directory (default: ./output)
OUTPUT_DIR=./output

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Max locations to scrape per company (0 = unlimited)
MAX_LOCATIONS_PER_COMPANY=0

# Playwright browser: chromium, firefox, webkit
BROWSER=chromium
